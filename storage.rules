rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — only the owner can write; anyone signed in can read
    match /profilePhotos/{userId}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // max 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Event images — approved teachers and superadmins can write
    match /eventImages/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
